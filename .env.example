# === Supabase ===
# Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
# Alleen server-side gebruikt (API route) — NOOIT met NEXT_PUBLIC_ prefix!
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# === Cloudinary ===
# Dashboard -> API Keys
CLOUDINARY_CLOUD_NAME=jouw-cloud-name
CLOUDINARY_API_KEY=123456789
CLOUDINARY_API_SECRET=abc...

# === Background removal (remove.bg) ===
# https://www.remove.bg/api — zonder key wordt de originele foto gebruikt (dev-fallback)
REMOVE_BG_API_KEY=

# === App ===
# Basis-URL voor de gedeelde game-links (zonder trailing slash)
NEXT_PUBLIC_APP_URL=http://localhost:3000
